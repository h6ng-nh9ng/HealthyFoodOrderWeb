@model HealthyFoodOrdering.ViewModels.DashboardVM
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var revenueLabelsJson = System.Text.Json.JsonSerializer.Serialize(Model.RevenueLabels);
    var revenueValuesJson = System.Text.Json.JsonSerializer.Serialize(Model.RevenueValues);
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
        <h2 class="text-dark fw-bold mb-0">
            <i class="fas fa-tachometer-alt text-success me-2"></i>Dashboard Quan Tri
        </h2>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 bg-white">
                <div class="card-header bg-transparent border-0 pt-3">
                    <h5 class="fw-bold text-secondary m-0">
                        <i class="fas fa-cogs me-2"></i>Cong cu quan ly
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <a href="/Admin/Product/Index" class="btn admin-menu-btn w-100 py-3 fw-bold shadow-sm">
                                <i class="fas fa-utensils fa-lg mb-2 d-block"></i> San pham
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="/Admin/Combo/Index" class="btn admin-menu-btn w-100 py-3 fw-bold shadow-sm">
                                <i class="fas fa-layer-group fa-lg mb-2 d-block"></i> Combo
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="/Admin/User/Index" class="btn btn-outline-primary w-100 py-3 fw-bold shadow-sm">
                                <i class="fas fa-users fa-lg mb-2 d-block"></i> Nguoi dung
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="/Admin/Order/Index" class="btn btn-outline-warning w-100 py-3 fw-bold shadow-sm text-dark">
                                <i class="fas fa-shopping-cart fa-lg mb-2 d-block"></i> Don hang
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl col-md-4 col-sm-6">
            <div class="card text-center shadow-sm border-0 hover-card h-100">
                <div class="card-body py-4">
                    <h6 class="text-uppercase text-muted fw-bold">San pham</h6>
                    <h2 class="display-6 fw-bold text-success">@Model.TotalProducts</h2>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4 col-sm-6">
            <div class="card text-center shadow-sm border-0 hover-card h-100">
                <div class="card-body py-4">
                    <h6 class="text-uppercase text-muted fw-bold">Danh muc</h6>
                    <h2 class="display-6 fw-bold text-info">@Model.TotalCategories</h2>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4 col-sm-6">
            <div class="card text-center shadow-sm border-0 hover-card h-100">
                <div class="card-body py-4">
                    <h6 class="text-uppercase text-muted fw-bold">Combo</h6>
                    <h2 class="display-6 fw-bold text-warning">@Model.TotalCombos</h2>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4 col-sm-6">
            <div class="card text-center shadow-sm border-0 hover-card h-100">
                <div class="card-body py-4">
                    <h6 class="text-uppercase text-muted fw-bold">Don hang</h6>
                    <h2 class="display-6 fw-bold text-primary">@Model.TotalOrders</h2>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4 col-sm-6">
            <div class="card text-center shadow-sm border-0 hover-card h-100">
                <div class="card-body py-4">
                    <h6 class="text-uppercase text-muted fw-bold">Doanh thu</h6>
                    <h2 class="display-6 fw-bold text-danger">@Model.Revenue.ToString("N0") <small class="fs-6">VND</small></h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="fw-bold text-secondary mb-1">
                                <i class="fas fa-chart-line text-success me-2"></i>Doanh thu
                            </h5>
                            <p class="text-muted small mb-0">7 ngay gan nhat, tinh theo don da hoan thanh.</p>
                        </div>
                    </div>
                </div>
                <div class="card-body px-4 pb-4">
                    <canvas id="revenueChart" height="120"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold text-secondary mb-0">
                        <i class="fas fa-star text-warning me-2"></i>Top san pham
                    </h5>
                </div>
                <div class="card-body px-4">
                    @if (Model.TopProducts.Any())
                    {
                        foreach (var item in Model.TopProducts)
                        {
                            <div class="d-flex align-items-center gap-3 py-3 border-bottom">
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-food.png" : item.ImageUrl)"
                                     alt="@item.Name"
                                     class="rounded-3 border"
                                     style="width: 56px; height: 56px; object-fit: cover;"
                                     onerror="this.src='/images/default-food.png'" />
                                <div class="flex-grow-1">
                                    <div class="fw-bold text-dark">@item.Name</div>
                                    <div class="text-muted small">Da ban @item.SoldQuantity mon</div>
                                </div>
                                <div class="fw-bold text-success text-end">@item.Revenue.ToString("N0")</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">Chua co du lieu san pham.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold text-secondary mb-0">
                        <i class="fas fa-receipt text-success me-2"></i>Don hang moi nhat
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Ma don</th>
                                    <th>Nguoi dat</th>
                                    <th>Ngay dat</th>
                                    <th>Tong tien</th>
                                    <th>Trang thai</th>
                                    <th class="text-end pe-4">Chi tiet</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.LatestOrders.Any())
                                {
                                    foreach (var order in Model.LatestOrders)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-primary">#@order.Id</td>
                                            <td>@order.ReceiverName</td>
                                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="fw-bold text-danger">@order.TotalAmount.ToString("N0") VND</td>
                                            <td>
                                                <span class="badge @OrderStatus.GetBadgeClass(order.Status)">
                                                    @OrderStatus.GetDisplayName(order.Status)
                                                </span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <a asp-area="Admin"
                                                   asp-controller="Order"
                                                   asp-action="Details"
                                                   asp-route-id="@order.Id"
                                                   class="btn btn-sm btn-outline-success">
                                                    Xem
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">Chua co don hang nao.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-card:hover {
        transform: translateY(-5px);
        transition: 0.3s;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }

    .admin-menu-btn {
        background: white;
        border: 2px solid #2f7d4f;
        color: #2f7d4f;
        font-weight: 600;
    }

        .admin-menu-btn:hover {
            background: #2f7d4f;
            color: white;
        }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const revenueLabels = @Html.Raw(revenueLabelsJson);
    const revenueValues = @Html.Raw(revenueValuesJson);
    const revenueCanvas = document.getElementById('revenueChart');

    if (revenueCanvas) {
        new Chart(revenueCanvas, {
            type: 'line',
            data: {
                labels: revenueLabels,
                datasets: [{
                    label: 'Doanh thu',
                    data: revenueValues,
                    borderColor: '#2f7d4f',
                    backgroundColor: 'rgba(47, 125, 79, 0.12)',
                    fill: true,
                    tension: 0.35,
                    pointRadius: 4,
                    pointBackgroundColor: '#2f7d4f'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: value => new Intl.NumberFormat('vi-VN').format(value)
                        }
                    }
                }
            }
        });
    }
</script>
