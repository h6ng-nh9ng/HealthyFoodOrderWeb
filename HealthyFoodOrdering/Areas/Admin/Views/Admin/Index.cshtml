@model HealthyFoodOrdering.ViewModels.DashboardVM
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Serialize tất cả dữ liệu biểu đồ thành JSON an toàn để truyền sang JavaScript
    var revenueLabelsJson = System.Text.Json.JsonSerializer.Serialize(Model.RevenueLabels);
    var revenueValuesJson = System.Text.Json.JsonSerializer.Serialize(Model.RevenueValues);
    var monthlyLabelsJson = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueLabels);
    var monthlyValuesJson = System.Text.Json.JsonSerializer.Serialize(Model.MonthlyRevenueValues);
    var statusLabelsJson = System.Text.Json.JsonSerializer.Serialize(Model.OrderStatusLabels);
    var statusCountsJson = System.Text.Json.JsonSerializer.Serialize(Model.OrderStatusCounts);
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
        <h2 class="text-dark fw-bold mb-0">
            <i class="fas fa-tachometer-alt text-success me-2"></i>Dashboard Quản Trị
        </h2>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 bg-white">
                <div class="card-header bg-transparent border-0 pt-3">
                    <h5 class="fw-bold text-secondary m-0">
                        <i class="fas fa-cogs me-2"></i>Công cụ quản lý
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <a href="/Admin/Product/Index" class="btn admin-menu-btn w-100 py-3 fw-bold shadow-sm">
                                <i class="fas fa-utensils fa-lg mb-2 d-block"></i> Sản phẩm
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="/Admin/Combo/Index" class="btn admin-menu-btn w-100 py-3 fw-bold shadow-sm">
                                <i class="fas fa-layer-group fa-lg mb-2 d-block"></i> Combo
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="/Admin/User/Index" class="btn btn-outline-primary w-100 py-3 fw-bold shadow-sm">
                                <i class="fas fa-users fa-lg mb-2 d-block"></i> Người dùng
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="/Admin/Order/Index" class="btn btn-outline-warning w-100 py-3 fw-bold shadow-sm text-dark">
                                <i class="fas fa-shopping-cart fa-lg mb-2 d-block"></i> Đơn hàng
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl col-md-4 col-sm-6">
            <div class="card text-center shadow-sm border-0 stat-card h-100" style="border-top: 3px solid #2f7d4f !important;">
                <div class="card-body py-4">
                    <div class="stat-icon bg-success-subtle rounded-circle mx-auto mb-2">
                        <i class="fas fa-utensils text-success"></i>
                    </div>
                    <h6 class="text-uppercase text-muted fw-bold small mb-1">Sản phẩm</h6>
                    <h2 class="display-6 fw-bold text-success mb-0">@Model.TotalProducts</h2>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4 col-sm-6">
            <div class="card text-center shadow-sm border-0 stat-card h-100" style="border-top: 3px solid #0dcaf0 !important;">
                <div class="card-body py-4">
                    <div class="stat-icon bg-info-subtle rounded-circle mx-auto mb-2">
                        <i class="fas fa-list-alt text-info"></i>
                    </div>
                    <h6 class="text-uppercase text-muted fw-bold small mb-1">Danh mục</h6>
                    <h2 class="display-6 fw-bold text-info mb-0">@Model.TotalCategories</h2>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4 col-sm-6">
            <div class="card text-center shadow-sm border-0 stat-card h-100" style="border-top: 3px solid #ffc107 !important;">
                <div class="card-body py-4">
                    <div class="stat-icon bg-warning-subtle rounded-circle mx-auto mb-2">
                        <i class="fas fa-layer-group text-warning"></i>
                    </div>
                    <h6 class="text-uppercase text-muted fw-bold small mb-1">Combo</h6>
                    <h2 class="display-6 fw-bold text-warning mb-0">@Model.TotalCombos</h2>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4 col-sm-6">
            <div class="card text-center shadow-sm border-0 stat-card h-100" style="border-top: 3px solid #0d6efd !important;">
                <div class="card-body py-4">
                    <div class="stat-icon bg-primary-subtle rounded-circle mx-auto mb-2">
                        <i class="fas fa-shopping-cart text-primary"></i>
                    </div>
                    <h6 class="text-uppercase text-muted fw-bold small mb-1">Đơn hàng</h6>
                    <h2 class="display-6 fw-bold text-primary mb-0">@Model.TotalOrders</h2>
                </div>
            </div>
        </div>
        <div class="col-xl col-md-4 col-sm-6">
            <div class="card text-center shadow-sm border-0 stat-card h-100" style="border-top: 3px solid #dc3545 !important;">
                <div class="card-body py-4">
                    <div class="stat-icon bg-danger-subtle rounded-circle mx-auto mb-2">
                        <i class="fas fa-wallet text-danger"></i>
                    </div>
                    <h6 class="text-uppercase text-muted fw-bold small mb-1">Doanh thu</h6>
                    <h2 class="display-6 fw-bold text-danger mb-0">
                        @Model.Revenue.ToString("N0")<small class="fs-6 ms-1">₫</small>
                    </h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">

        @* Biểu đồ doanh thu (line chart với nút chuyển ngày / tháng) *@
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-2">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <h5 class="fw-bold text-secondary mb-1">
                                <i class="fas fa-chart-area text-success me-2"></i>Biểu đồ doanh thu
                            </h5>
                            <p class="text-muted small mb-0">
                                Chỉ tính đơn hàng đã hoàn thành
                            </p>
                        </div>
                        @* Nút chuyển khoảng thời gian *@
                        <div class="btn-group btn-group-sm" role="group" aria-label="Khoảng thời gian">
                            <button type="button" class="btn btn-success" id="btnDaily">
                                <i class="fas fa-calendar-day me-1"></i>7 ngày
                            </button>
                            <button type="button" class="btn btn-outline-success" id="btnMonthly">
                                <i class="fas fa-calendar-alt me-1"></i>6 tháng
                            </button>
                        </div>
                    </div>
                </div>
                <div class="card-body px-4 pb-4 pt-2">
                    <canvas id="revenueChart" height="115"></canvas>
                </div>
            </div>
        </div>

        @* Biểu đồ trạng thái đơn hàng (doughnut) *@
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-2">
                    <h5 class="fw-bold text-secondary mb-1">
                        <i class="fas fa-chart-pie text-info me-2"></i>Trạng thái đơn hàng
                    </h5>
                    <p class="text-muted small mb-0">Phân bổ theo trạng thái hiện tại</p>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center px-3 pb-4 pt-2">
                    @if (Model.OrderStatusLabels.Any())
                    {
                        <canvas id="statusChart" style="max-height: 260px;"></canvas>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="fas fa-inbox fa-2x mb-2 d-block opacity-25"></i>
                            Chưa có đơn hàng nào.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        @* Top 5 sản phẩm bán chạy *@
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold text-secondary mb-0">
                        <i class="fas fa-star text-warning me-2"></i>Top sản phẩm bán chạy
                    </h5>
                </div>
                <div class="card-body px-4 pb-4">
                    @if (Model.TopProducts.Any())
                    {
                        foreach (var item in Model.TopProducts)
                        {
                            <div class="d-flex align-items-center gap-3 py-3 border-bottom">
                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-food.png" : item.ImageUrl)"
                                     alt="@item.Name"
                                     class="rounded-3 border"
                                     style="width: 54px; height: 54px; object-fit: cover; flex-shrink: 0;"
                                     onerror="this.src='/images/default-food.png'" />
                                <div class="flex-grow-1" style="min-width:0;">
                                    <div class="fw-bold text-dark text-truncate">@item.Name</div>
                                    <div class="text-muted small">Đã bán @item.SoldQuantity món</div>
                                </div>
                                <div class="fw-semibold text-success text-nowrap small">
                                    @item.Revenue.ToString("N0") ₫
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="fas fa-box-open fa-2x mb-2 d-block opacity-25"></i>
                            Chưa có dữ liệu sản phẩm.
                        </div>
                    }
                </div>
            </div>
        </div>

        @* 5 đơn hàng mới nhất *@
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold text-secondary mb-0">
                        <i class="fas fa-receipt text-success me-2"></i>Đơn hàng mới nhất
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Mã đơn</th>
                                    <th>Người đặt</th>
                                    <th>Ngày đặt</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                    <th class="text-end pe-4">Chi tiết</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.LatestOrders.Any())
                                {
                                    foreach (var order in Model.LatestOrders)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-primary">#@order.Id</td>
                                            <td>@order.ReceiverName</td>
                                            <td class="text-muted small">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="fw-bold text-danger">@order.TotalAmount.ToString("N0") ₫</td>
                                            <td>
                                                <span class="badge @OrderStatus.GetBadgeClass(order.Status)">
                                                    @OrderStatus.GetDisplayName(order.Status)
                                                </span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <a asp-area="Admin"
                                                   asp-controller="Order"
                                                   asp-action="Details"
                                                   asp-route-id="@order.Id"
                                                   class="btn btn-sm btn-outline-success">
                                                    Xem
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-5">
                                            <i class="fas fa-inbox fa-2x mb-2 d-block opacity-25"></i>
                                            Chưa có đơn hàng nào.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    /* ── Stat cards ─────────────────────────────────────────────────────── */
    .stat-card {
        transition: transform 0.22s ease, box-shadow 0.22s ease;
        cursor: default;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 14px 28px rgba(0, 0, 0, 0.09) !important;
        }

    .stat-icon {
        width: 46px;
        height: 46px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
    }

    /* ── Admin menu buttons ─────────────────────────────────────────────── */
    .admin-menu-btn {
        background: #fff;
        border: 2px solid #2f7d4f;
        color: #2f7d4f;
        font-weight: 600;
        transition: background 0.2s, color 0.2s;
    }

        .admin-menu-btn:hover {
            background: #2f7d4f;
            color: #fff;
        }

    /* ── Subtle hover on all other cards ───────────────────────────────── */
    .hover-card:hover {
        transform: translateY(-4px);
        transition: 0.25s;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08) !important;
    }
</style>

@* Chart.js v4 từ CDN *@
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
    // ── Dữ liệu từ server (an toàn nhờ System.Text.Json) ─────────────────────
    const dailyLabels   = @Html.Raw(revenueLabelsJson);
    const dailyValues   = @Html.Raw(revenueValuesJson);
    const monthlyLabels = @Html.Raw(monthlyLabelsJson);
    const monthlyValues = @Html.Raw(monthlyValuesJson);
    const statusLabels  = @Html.Raw(statusLabelsJson);
    const statusCounts  = @Html.Raw(statusCountsJson);

    // ── Helpers định dạng số ─────────────────────────────────────────────────
    const formatVND = v =>
    new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(v);

    /** Rút gọn trục Y: 1.500.000 → 1.5M, 250.000 → 250K */
    const formatShort = v => {
    if (v >= 1e9) return (v / 1e9).toFixed(1) + 'T';
    if (v >= 1e6) return (v / 1e6).toFixed(1) + 'M';
    if (v >= 1e3) return (v / 1e3).toFixed(0) + 'K';
    return v.toString();
    };

    // ────────────────────────────────────────────────────────────────────────
    // BIỂU ĐỒ DOANH THU (Line Chart – gradient fill)
    // ────────────────────────────────────────────────────────────────────────
    (function () {
    const canvas = document.getElementById('revenueChart');
    if (!canvas) return;

    const ctx = canvas.getContext('2d');

    // Gradient nền từ xanh lá đậm (trên) → trong suốt (dưới)
    const gradient = ctx.createLinearGradient(0, 0, 0, 340);
    gradient.addColorStop(0, 'rgba(47,125,79,0.28)');
    gradient.addColorStop(1, 'rgba(47,125,79,0.00)');

    /** Tạo mảng dataset cho Chart.js */
    function makeDataset(values) {
    return [{
    label: 'Doanh thu',
    data: values,
    borderColor: '#2f7d4f',
    backgroundColor: gradient,
    fill: true,
    tension: 0.45,
    pointRadius: 5,
    pointBackgroundColor: '#fff',
    pointBorderColor: '#2f7d4f',
    pointBorderWidth: 2.5,
    pointHoverRadius: 8,
    pointHoverBackgroundColor: '#2f7d4f',
    pointHoverBorderColor: '#fff',
    pointHoverBorderWidth: 2
    }];
    }

    const revenueChart = new Chart(ctx, {
    type: 'line',
    data: {
    labels: dailyLabels,
    datasets: makeDataset(dailyValues)
    },
    options: {
    responsive: true,
    maintainAspectRatio: true,
    interaction: { mode: 'index', intersect: false },
    plugins: {
    legend: { display: false },
    tooltip: {
    backgroundColor: 'rgba(20,20,20,0.88)',
    titleFont: { size: 13, weight: '600' },
    bodyFont:  { size: 13 },
    padding: 13,
    cornerRadius: 8,
    displayColors: false,
    callbacks: {
    title: items => items[0].label,
    label: ctx  => '  ' + formatVND(ctx.parsed.y)
    }
    }
    },
    scales: {
    x: {
    grid:   { display: false },
    border: { display: false },
    ticks:  { color: '#8a9099', font: { size: 12 } }
    },
    y: {
    beginAtZero: true,
    grid:   { color: 'rgba(0,0,0,0.05)' },
    border: { display: false },
    ticks:  {
    color: '#8a9099',
    font:  { size: 12 },
    callback: formatShort
    }
    }
    },
    animation: { duration: 550, easing: 'easeInOutQuart' }
    }
    });

    // ── Nút chuyển 7 ngày / 6 tháng ────────────────────────────────────
    const btnDaily   = document.getElementById('btnDaily');
    const btnMonthly = document.getElementById('btnMonthly');

    function switchPeriod(labels, values, activeBtn, inactiveBtn) {
    revenueChart.data.labels   = labels;
    revenueChart.data.datasets = makeDataset(values);
    revenueChart.update('active');
    activeBtn.classList.remove('btn-outline-success');
    activeBtn.classList.add('btn-success');
    inactiveBtn.classList.remove('btn-success');
    inactiveBtn.classList.add('btn-outline-success');
    }

    btnDaily.addEventListener('click', () =>
    switchPeriod(dailyLabels, dailyValues, btnDaily, btnMonthly));

    btnMonthly.addEventListener('click', () =>
    switchPeriod(monthlyLabels, monthlyValues, btnMonthly, btnDaily));
    })();

    // ────────────────────────────────────────────────────────────────────────
    // BIỂU ĐỒ TRẠNG THÁI ĐƠN HÀNG (Doughnut Chart)
    // ────────────────────────────────────────────────────────────────────────
    (function () {
    const canvas = document.getElementById('statusChart');
    if (!canvas || statusLabels.length === 0) return;

    // Màu lần lượt: chờ xác nhận, đang xử lý, đang giao, hoàn thành, đã hủy, khác
    const palette = ['#ffc107', '#0d6efd', '#fd7e14', '#28a745', '#dc3545', '#6c757d'];

    new Chart(canvas, {
    type: 'doughnut',
    data: {
    labels: statusLabels,
    datasets: [{
    data: statusCounts,
    backgroundColor: palette.slice(0, statusLabels.length),
    borderWidth: 3,
    borderColor: '#fff',
    hoverOffset: 10
    }]
    },
    options: {
    responsive: true,
    cutout: '72%',
    plugins: {
    legend: {
    position: 'bottom',
    labels: {
    padding: 14,
    font: { size: 12 },
    usePointStyle: true,
    pointStyleWidth: 10
    }
    },
    tooltip: {
    callbacks: {
    label: ctx => ` ${ctx.label}: ${ctx.parsed} đơn`
    }
    }
    },
    animation: { animateScale: true, duration: 650 }
    }
    });
    })();
</script>
