@model IEnumerable<HealthyFoodOrdering.Models.NutritionCombo>

@{
    ViewData["Title"] = "Quản lý Combo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">🥗 Quản lý Combos</h2>
            <small class="text-muted">Tổng: @Model.Count() combo</small>
        </div>
        <a asp-action="Create" class="btn btn-success rounded-pill px-4">
            <i class="fas fa-plus me-1"></i> Tạo Combo mới
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4 rounded-top-start-4" style="width:80px;">Ảnh</th>
                        <th>Tên Combo</th>
                        <th>Giá</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <img src="@Url.Content("~/" + (item.ImageUrl ?? "images/placeholder-combo.jpg").TrimStart('/'))"
                                     alt="@item.ComboName"
                                     style="width:56px; height:56px; object-fit:cover; border-radius:8px;"
                                     onerror="this.onerror=null; this.src='/images/placeholder-combo.jpg';" />
                            </td>
                            <td class="fw-semibold">@item.ComboName</td>
                            <td class="text-success fw-bold">@item.TotalPrice.ToString("N0") VNĐ</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success rounded-pill">✅ Hiển thị</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary rounded-pill">🚫 Ẩn</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill me-1">
                                    <i class="fas fa-pen"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill">
                                    <i class="fas fa-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <p>Chưa có combo nào. Hãy tạo combo đầu tiên!</p>
        </div>
    }

</div>
