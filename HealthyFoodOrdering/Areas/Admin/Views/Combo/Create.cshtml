@model HealthyFoodOrdering.Models.NutritionCombo

<div class="container py-5">
    <h2>Tạo mới Combo</h2>
    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label>Tên Combo</label>
            <input asp-for="ComboName" class="form-control" required />
        </div>
        
        <div class="mb-3">
            <label>Chọn các sản phẩm trong Combo:</label>
            <div class="border p-3 rounded" style="max-height: 300px; overflow-y: scroll;">
                @foreach (var product in ViewBag.Products)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="selectedProducts" value="@product.Id" id="p_@product.Id">
                        <label class="form-check-label" for="p_@product.Id">
                            @product.Name (@product.Price.ToString("N0") VNĐ)
                        </label>
                    </div>
                }
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Lưu Combo</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </form>
</div>