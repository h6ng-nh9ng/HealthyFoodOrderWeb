@model HealthyFoodOrdering.Models.NutritionCombo
<div class="container py-5">
    <h2 class="mb-4">Chỉnh sửa Combo</h2>
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label>Tên Combo</label>
            <input asp-for="ComboName" class="form-control" />
        </div>
        <div class="mb-3">
            <label>Sản phẩm trong Combo</label>
            <div class="border p-3 rounded" style="max-height: 200px; overflow-y: auto;">
                @foreach (var p in ViewBag.Products)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="selectedProducts" value="@p.Id"
                        @(Model.ComboDetails.Any(cd => cd.ProductId == p.Id) ? "checked" : "")>
                        <label class="form-check-label">@p.Name</label>
                    </div>
                }
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </form>
</div>