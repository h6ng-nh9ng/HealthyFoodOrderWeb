@model HealthyFoodOrdering.Models.Product
@{
    ViewData["Title"] = "Xóa Món Ăn Khỏi Hệ Thống";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-card mx-auto" style="max-width: 600px;">
    <div class="text-center mb-4">
        <div class="text-danger mb-3">
            <i class="fas fa-exclamation-triangle fa-3x"></i>
        </div>
        <h3 class="fw-bold text-dark">Bạn muốn gỡ bỏ món ăn này?</h3>
        <p class="text-muted">Hành động này sẽ xóa vĩnh viễn dữ liệu khỏi trang thực đơn của khách hàng.</p>
    </div>

    <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-4 mb-4 border">
        <img src="@Model.ImageUrl" class="rounded-3 border" style="width: 80px; height: 80px; object-fit: cover;" />
        <div>
            <h5 class="fw-bold m-0 text-dark">@Model.Name</h5>
            <span class="badge bg-success mt-1">Calo: @Model.Calories kcal</span>
            <p class="m-0 text-danger fw-bold mt-1">@Model.FinalPrice.ToString("#,##0") đ</p>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-6">
                <a href="/Product" class="btn btn-light border w-100 py-2.5 fw-semibold" style="border-radius: 10px;">
                    Không xóa, quay lại
                </a>
            </div>
            <div class="col-6">
                <button type="submit" class="btn btn-danger w-100 py-2.5 fw-bold" style="border-radius: 10px;">
                    Xác nhận xóa ngay
                </button>
            </div>
        </div>
    </form>
</div>