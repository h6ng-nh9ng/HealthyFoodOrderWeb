@model HealthyFoodOrdering.Models.Product
@{
    ViewData["Title"] = "Thêm Món Ăn Mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-success text-white text-center py-3 rounded-top-4">
                    <h3 class="mb-0"><i class="fas fa-utensils"></i> Thêm Món Ăn Mới</h3>
                </div>
                
                <form asp-action="Create" method="post" enctype="multipart/form-data" class="p-4">
                    <div class="row">
                        <div class="col-md-6">
                            <label class="fw-bold mb-1">Tên món ăn</label>
                            <input asp-for="Name" class="form-control mb-3" required />
                            
                            <label class="fw-bold mb-1">Danh mục</label>
                            <select asp-for="CategoryId" class="form-select mb-3" asp-items="ViewBag.CategoryId">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                            <label class="fw-bold mb-1">Mô tả</label>
                            <textarea asp-for="Description" class="form-control mb-3" rows="3"></textarea>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="fw-bold mb-1">Giá bán</label>
                            <input asp-for="Price" type="number" class="form-control mb-3" />
                            
                            <label class="fw-bold mb-1">Hình ảnh</label>
                            <input type="file" name="imageFile" class="form-control mb-3" accept="image/*" />

                            <div class="row">
                                <div class="col-6"><label class="small fw-bold">Calo</label><input asp-for="Calories" class="form-control mb-2" /></div>
                                <div class="col-6"><label class="small fw-bold">Protein</label><input asp-for="Protein" class="form-control mb-2" /></div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a href="/Admin/Product/Index" class="btn btn-outline-secondary px-4">
                            <i class="fas fa-arrow-left"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-success px-4">Lưu món ăn</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>