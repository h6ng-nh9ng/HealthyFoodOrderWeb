@model IEnumerable<HealthyFoodOrdering.Models.Product>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Danh sách Món ăn";
}

<div class="container py-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-white py-4 border-0">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="fw-bold text-success mb-0">
                    <i class="fas fa-tasks me-2"></i>Quản Lý Thực Đơn
                </h2>
                <a asp-action="Create" class="btn btn-success px-4 rounded-pill shadow-sm">
                    <i class="fas fa-plus-circle me-2"></i>Thêm món mới
                </a>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4" style="width: 100px;">Ảnh</th>
                            <th>Tên món ăn</th>
                            <th>Danh mục</th>
                            <th class="text-center">Dinh dưỡng</th>
                            <th class="text-end">Giá bán</th>
                            <th class="text-center pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-food.png" : item.ImageUrl)"
                                         class="rounded-3 shadow-sm"
                                         style="width: 70px; height: 70px; object-fit: cover;"
                                         onerror="this.src='/images/default-food.png'" />
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.Name</div>
                                    <small class="text-muted">ID: #@item.Id</small>
                                </td>
                                <td>
                                    <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2 rounded-pill">
                                        @item.Category?.Name
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="small">🔥 <strong>@item.Calories</strong> kcal</div>
                                    <div class="small text-muted">🥩 <strong>@item.Protein</strong>g Protein</div>
                                </td>
                                <td class="text-end fw-bold text-success">
                                    @item.Price.ToString("N0") VNĐ
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white text-primary border-end" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-white text-danger" title="Xóa">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        <div class="card-footer bg-white py-3 border-0 text-center">
            <p class="text-muted small mb-0">Hiển thị @Model.Count() món ăn trong thực đơn hiện tại</p>
        </div>
    </div>
</div>

<style>
    /* Làm bảng trông thoáng và chuyên nghiệp hơn */
    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 700;
        color: #6c757d;
        padding-top: 1.5rem;
        padding-bottom: 1.5rem;
    }

    .table tbody td {
        padding-top: 1.2rem;
        padding-bottom: 1.2rem;
    }

    .btn-white {
        background-color: #fff;
    }

        .btn-white:hover {
            background-color: #f8f9fa;
        }
</style>