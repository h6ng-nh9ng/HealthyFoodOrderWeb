@model HealthyFoodOrdering.Models.Category
@{
    ViewData["Title"] = "Chi tiết danh mục";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                @if (Model == null)
                {
                    <div class="card-body p-5 text-center text-muted">
                        Không tìm thấy danh mục.
                    </div>
                }
                else
                {
                    <div class="row g-0">
                        <div class="col-md-5">
                            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/default-food.png" : Model.ImageUrl)"
                                 alt="@Model.Name"
                                 class="w-100 h-100"
                                 style="min-height: 320px; object-fit: cover;"
                                 onerror="this.src='/images/default-food.png'" />
                        </div>
                        <div class="col-md-7">
                            <div class="card-body p-4 p-lg-5">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                    <div>
                                        <h2 class="fw-bold text-success mb-1">@Model.Name</h2>
                                        <span class="text-muted">ID: #@Model.Id</span>
                                    </div>
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill">Đang hiển thị</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2 rounded-pill">Đang ẩn</span>
                                    }
                                </div>

                                <div class="mb-4">
                                    <h6 class="fw-bold text-uppercase text-muted small">Mô tả</h6>
                                    <p class="text-dark mb-0">@(string.IsNullOrWhiteSpace(Model.Description) ? "Chưa có mô tả." : Model.Description)</p>
                                </div>

                                <div class="row g-3 mb-4">
                                    <div class="col-sm-6">
                                        <div class="p-3 bg-light rounded-4 border">
                                            <div class="text-muted small">Số món trong danh mục</div>
                                            <div class="fs-4 fw-bold text-success">@(Model.Products?.Count ?? 0)</div>
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <div class="p-3 bg-light rounded-4 border">
                                            <div class="text-muted small">Đường dẫn ảnh</div>
                                            <div class="small text-break">@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "Chưa có" : Model.ImageUrl)</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex flex-wrap gap-2 pt-3 border-top">
                                    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary px-4">
                                        <i class="fas fa-arrow-left me-1"></i>Quay lại
                                    </a>
                                    <a asp-area="Admin" asp-controller="Category" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 fw-bold">
                                        <i class="fas fa-edit me-1"></i>Sửa
                                    </a>
                                    <a asp-area="Admin" asp-controller="Category" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger px-4">
                                        <i class="fas fa-trash-alt me-1"></i>Xóa
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
