@model HealthyFoodOrdering.Models.Category
@{
    ViewData["Title"] = "Thêm danh mục";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-success text-white text-center py-3 rounded-top-4">
                    <h3 class="mb-0"><i class="fas fa-layer-group me-2"></i>Thêm Danh Mục Mới</h3>
                </div>

                <form asp-area="Admin" asp-controller="Category" asp-action="Create" method="post" class="p-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label fw-bold">Đường dẫn hình ảnh</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="/images/categories/salad.jpg hoặc https://..." />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label fw-bold">Hiển thị danh mục</label>
                    </div>

                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="fas fa-arrow-left me-1"></i>Quay lại
                        </a>
                        <button type="submit" class="btn btn-success px-4">
                            <i class="fas fa-save me-1"></i>Lưu danh mục
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
