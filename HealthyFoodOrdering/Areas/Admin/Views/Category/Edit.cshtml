@model HealthyFoodOrdering.Models.Category
@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-warning text-dark py-3 rounded-top-4">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                        <div>
                            <h3 class="fw-bold mb-1"><i class="fas fa-edit me-2"></i>Cập Nhật Danh Mục</h3>
                            <p class="mb-0 small">Đang chỉnh sửa: <span class="fw-bold">@Model?.Name</span></p>
                        </div>
                        <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-light border px-3">
                            <i class="fas fa-arrow-left me-1"></i>Quay lại
                        </a>
                    </div>
                </div>

                @if (Model == null)
                {
                    <div class="card-body p-4 text-center text-muted">
                        Không tìm thấy danh mục cần chỉnh sửa.
                    </div>
                }
                else
                {
                    <form asp-area="Admin" asp-controller="Category" asp-action="Edit" method="post" class="p-4">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label fw-bold">Đường dẫn hình ảnh</label>
                            <input asp-for="ImageUrl" class="form-control" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Xem trước hình ảnh</label>
                            <div>
                                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/default-food.png" : Model.ImageUrl)"
                                     alt="@Model.Name"
                                     class="img-thumbnail rounded-3"
                                     style="width: 160px; height: 120px; object-fit: cover;"
                                     onerror="this.src='/images/default-food.png'" />
                            </div>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label fw-bold">Hiển thị danh mục</label>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-4 pt-3 border-top">
                            <a asp-area="Admin" asp-controller="Category" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info px-4">
                                <i class="fas fa-eye me-1"></i>Chi tiết
                            </a>
                            <button type="submit" class="btn btn-warning px-4 fw-bold">
                                <i class="fas fa-save me-1"></i>Lưu thay đổi
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
