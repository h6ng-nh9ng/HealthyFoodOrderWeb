@model HealthyFoodOrdering.Models.Order
@{
    ViewData["Title"] = "Cap Nhat Trang Thai Don Hang";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string? nextStatus = ViewBag.NextStatus as string;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-success text-white py-3 rounded-top-4">
                    <h3 class="mb-0">
                        <i class="fas fa-clipboard-check me-2"></i>Cap nhat trang thai don hang #@Model.Id
                    </h3>
                </div>

                <div class="card-body p-4">
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-4 border h-100">
                                <div class="text-muted small">Khach hang</div>
                                <div class="fw-bold">@Model.ReceiverName</div>
                                <div class="text-muted small mt-1">@Model.Phone</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-4 border h-100">
                                <div class="text-muted small">Tong tien</div>
                                <div class="fw-bold text-danger">@Model.TotalAmount.ToString("N0") VND</div>
                                <div class="text-muted small mt-1">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5 class="fw-bold mb-3">Quy trinh trang thai</h5>
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            @foreach (var status in OrderStatus.Workflow)
                            {
                                <span class="badge @OrderStatus.GetBadgeClass(status) px-3 py-2">
                                    @OrderStatus.GetDisplayName(status)
                                </span>

                                @if (status != OrderStatus.Workflow.Last())
                                {
                                    <span class="text-muted">
                                        <i class="fas fa-arrow-right"></i>
                                    </span>
                                }
                            }
                        </div>
                    </div>

                    <div class="p-4 border rounded-4 mb-4">
                        <div class="text-muted small mb-1">Trang thai hien tai</div>
                        <span class="badge @OrderStatus.GetBadgeClass(Model.Status) px-3 py-2">
                            @OrderStatus.GetDisplayName(Model.Status)
                        </span>

                        @if (nextStatus == null)
                        {
                            <div class="alert alert-success mt-4 mb-0">
                                Don hang da o trang thai cuoi cung.
                            </div>
                        }
                        else
                        {
                            <div class="mt-4">
                                <div class="text-muted small mb-1">Trang thai tiep theo</div>
                                <span class="badge @OrderStatus.GetBadgeClass(nextStatus) px-3 py-2">
                                    @OrderStatus.GetDisplayName(nextStatus)
                                </span>
                            </div>
                        }
                    </div>

                    <form asp-area="Admin" asp-controller="Order" asp-action="UpdateStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="status" value="@nextStatus" />

                        <div class="d-flex justify-content-end gap-3">
                            <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-outline-secondary px-4">
                                Quay lai
                            </a>

                            @if (nextStatus != null)
                            {
                                <button type="submit" class="btn btn-success px-4 fw-bold">
                                    Chuyen sang @OrderStatus.GetDisplayName(nextStatus)
                                </button>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
