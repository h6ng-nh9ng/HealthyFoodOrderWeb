@model IEnumerable<HealthyFoodOrdering.Models.Order>
@{
    ViewData["Title"] = "Quan Ly Don Hang";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-success mb-1">Quan ly don hang</h2>
            <p class="text-muted mb-0">Theo doi va cap nhat trang thai don hang theo dung quy trinh.</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle shadow-sm bg-white">
            <thead class="admin-table-header">
                <tr>
                    <th>Ma</th>
                    <th>Khach hang</th>
                    <th>Ngay dat</th>
                    <th>Tong tien</th>
                    <th>Trang thai</th>
                    <th class="text-center">Hanh dong</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-primary">#@item.Id</td>
                        <td>@item.ReceiverName</td>
                        <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="fw-bold text-danger">@item.TotalAmount.ToString("N0") VND</td>
                        <td>
                            <span class="badge @OrderStatus.GetBadgeClass(item.Status)">
                                @OrderStatus.GetDisplayName(item.Status)
                            </span>
                        </td>
                        <td class="text-center">

                            <a asp-area="Admin"
                                   asp-controller="Order"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-detail">
                                Chi tiet
                            </a>

                            @if (item.Status == OrderStatus.WaitingConfirm)
                            {
                                <a asp-area="Admin"
                                       asp-controller="Order"
                                       asp-action="ConfirmPayment"
                                       asp-route-id="@item.Id"
                                       class="btn btn-success btn-sm">
                                    Xac nhan thanh toan
                                </a>
                            }
                            else
                            {
                                <a asp-area="Admin"
                                       asp-controller="Order"
                                       asp-action="UpdateStatus"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-update">
                                    Cap nhat
                                </a>
                            }

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<style>

    .btn-detail {
        background: #eff6ff;
        color: #2563eb;
        border: 1px solid #2563eb;
        font-weight: 600;
    }

        .btn-detail:hover {
            background: #2563eb;
            color: white;
        }

    .btn-update {
        background: #2f7d4f;
        border: none;
        color: white;
        font-weight: 600;
    }

        .btn-update:hover {
            background: #24633e;
        }

    .admin-table-header th {
        background-color: #2f7d4f !important;
        color: white !important;
        border-color: #2f7d4f !important;
    }
</style>