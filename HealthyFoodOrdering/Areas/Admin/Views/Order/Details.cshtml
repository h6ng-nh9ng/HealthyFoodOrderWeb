@model HealthyFoodOrdering.Models.Order
@{
    ViewData["Title"] = "Chi Tiet Don Hang";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold text-success mb-1">Chi tiet don hang #@Model.Id</h2>
            <p class="text-muted mb-0">Xem nguoi dat, danh sach mon, tong tien va trang thai don hang.</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-area="Admin"
               asp-controller="Order"
               asp-action="Index"
               class="btn btn-outline-dark fw-bold">
                Quay lai
            </a>
            <a asp-area="Admin"
                   asp-controller="Order"
                   asp-action="UpdateStatus"
                   asp-route-id="@Model.Id"
                   class="btn btn-success fw-bold px-4">
                Cap nhat trang thai
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <div class="text-muted small">Trang thai</div>
                            <span class="badge @OrderStatus.GetBadgeClass(Model.Status) px-3 py-2 mt-1">
                                @OrderStatus.GetDisplayName(Model.Status)
                            </span>
                        </div>
                        <div class="text-end">
                            <div class="text-muted small">Ngay dat</div>
                            <div class="fw-semibold">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                    </div>

                    <h5 class="fw-bold text-success mb-3">Nguoi dat</h5>

                    <div class="mb-3">
                        <div class="text-muted small">Ten nguoi nhan</div>
                        <div class="fw-bold">@Model.ReceiverName</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Tai khoan</div>
                        <div class="fw-semibold">@(Model.User?.FullName ?? Model.User?.UserName ?? "Khach hang")</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">So dien thoai</div>
                        <div class="fw-semibold">@Model.Phone</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Dia chi</div>
                        <div class="fw-semibold">@Model.Address</div>
                    </div>

                    <div>
                        <div class="text-muted small">Thanh toan</div>
                        <span class="badge bg-info text-dark">@Model.PaymentMethod</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold text-success mb-0">Danh sach mon</h5>
                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill">
                            @Model.OrderDetails.Count mon
                        </span>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Mon an</th>
                                    <th class="text-center">So luong</th>
                                    <th class="text-end">Don gia</th>
                                    <th class="text-end">Thanh tien</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detail in Model.OrderDetails)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="@(string.IsNullOrEmpty(detail.Product?.ImageUrl) ? "/images/default-food.png" : detail.Product.ImageUrl)"
                                                     alt="@detail.Product?.Name"
                                                     class="rounded-3 border"
                                                     style="width: 64px; height: 64px; object-fit: cover;"
                                                     onerror="this.src='/images/default-food.png'" />
                                                <div>
                                                    <div class="fw-bold text-dark">
                                                        @(detail.Product?.Name
                                                            ?? detail.Combo?.ComboName
                                                            ?? "San pham")
                                                    </div>
                                                    <div class="text-muted small">
                                                        @(detail.ProductId != null
                                                            ? $"Mã món: #{detail.ProductId}"
                                                            : $"Mã combo: #{detail.ComboId}")
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-light text-dark border">x@detail.Quantity</span>
                                        </td>
                                        <td class="text-end">@detail.Price.ToString("N0") VND</td>
                                        <td class="text-end fw-bold text-success">@((detail.Price * detail.Quantity).ToString("N0")) VND</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="border-top mt-4 pt-4">
                        <div class="d-flex justify-content-between align-items-center
                            <span class="fs-5 fw-bold text-dark">Tong tien</span>
                            <span class="fs-4 fw-bold text-success">@Model.TotalAmount.ToString("N0") VND</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>