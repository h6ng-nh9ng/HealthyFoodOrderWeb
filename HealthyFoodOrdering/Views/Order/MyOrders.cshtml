@model IEnumerable<HealthyFoodOrdering.Models.Order>

<div class="container mt-4">
    <h2>Lịch sử đơn hàng</h2>
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }
    <table class="table table-striped align-middle text-center">
        <thead class="table-dark">
            <tr>
                <th>Mã đơn</th>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Thanh toán</th>
                <th>Trạng thái</th>
                <th>Chi tiết</th>
                <th>Hủy đơn</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold text-primary">#@item.Id</td>
                    
                    <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    
                    <td class="fw-bold text-danger">@item.TotalAmount.ToString("N0") VNĐ</td>
                    
                    <td>
                        <span class="badge @(item.PaymentMethod == "QR"
                                              ? "bg-info text-dark"
                                              : "bg-warning text-dark")">
                            @item.PaymentMethod
                        </span>
                    </td>
                    
                    <td>
                        <span class="@OrderStatus.GetBadgeClass(item.Status)">
                            @OrderStatus.GetDisplayName(item.Status)
                        </span>
                    </td>

                    <td>
                        <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-primary btn-sm">
                            Xem
                        </a>
                    </td>

                    <td>
                        @if (item.Status == OrderStatus.Pending ||
                             item.Status == OrderStatus.Confirmed)
                        {
                            <a asp-action="Cancel"
                                   asp-route-id="@item.Id"
                                   class="btn btn-cancel-order btn-sm"
                                   onclick="return confirm('Bạn có chắc muốn hủy đơn?')">
                                Hủy
                            </a>
                        }
                    </td>
                    
                </tr>
            }
        </tbody>
    </table>
</div>

<style>

    .btn-cancel-order {
        background: #dc2626;
        color: white;
        border: none;
        font-weight: 600;
    }

        .btn-cancel-order:hover {
            background: #b91c1c;
        }
</style>
