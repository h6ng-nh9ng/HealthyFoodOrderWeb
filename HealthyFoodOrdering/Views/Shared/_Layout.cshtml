@using System.Text.Json
@using HealthyFoodOrdering.Models

@{
    var cartSession = Context.Session.GetString("Cart");

    var cart = string.IsNullOrEmpty(cartSession)
        ? new List<CartItem>()
        : JsonSerializer.Deserialize<List<CartItem>>(cartSession);

    var cartCount = cart?.Sum(x => x.Quantity) ?? 0;
}

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Healthy Food Ordering</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet"
          href="~/css/style.css"
          asp-append-version="true" />

  </head>

  <body>
    <header class="navbar">
      <div class="container nav-content">
        <div class="logo">
          <div class="logo-icon">🌿</div>
          <span>Healthy Food</span>
        </div>

            <nav>
                <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                <a asp-area="" asp-controller="Product" asp-action="Index">Products</a>
                <a asp-area="" asp-controller="Combo" asp-action="Index">Combos</a>
                <a href="/Home/Index#about">About</a>
                <a href="/Home/Index#contact">Contact</a>
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-area=""
                           asp-controller="Order"
                           asp-action="MyOrders">
                        My Orders
                    </a>
                }

            </nav>

            <a asp-area=""
                   asp-controller="Cart"
                   asp-action="Index"
                   class="cart-btn text-decoration-none">
                Cart (<span id="cartCount">@cartCount</span>)
            </a>

            <partial name="_LoginPartial" />
      </div>
    </header>

    @RenderBody()

    <footer class="footer">
    <div class="container">
        <div class="footer-top">
            <p class="footer-badge">Student Project — No Real Orders Processed</p>

            <h2>Ready to Eat Healthy?</h2>

            <p class="footer-text">
                Browse our menu, add meals to your cart, and explore how this
                ordering UI works.
            </p>

            <button class="primary-btn" onclick="scrollToMenu()">
                View the Menu
            </button>
        </div>

        <div class="footer-grid">
            <div>
                <h3>Healthy Food</h3>

                <p>
                    A student project for exploring healthy meal ordering. Not a real
                    business.
                </p>
            </div>

            <div>
                <h4>Explore</h4>

                <a href="#home">Home</a>
                <a href="#menu">Menu</a>
                <a href="#categories">Categories</a>
                <a href="#about">About</a>
            </div>

            <div>
                <h4>Menu</h4>

                <a href="#">Salad Bowls</a>
                <a href="#">Breakfast</a>
                <a href="#">Smoothie Bowls</a>
                <a href="#">Smoothies</a>
                <a href="#">Wraps</a>
            </div>
        </div>
    </div>
</footer>

    <script src="~/js/app.js"
            asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>