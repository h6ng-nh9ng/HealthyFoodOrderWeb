@* ─────────────────────────────────────────────────────────────────
   Views/Cart/Index.cshtml  —  snippet phần table body
   Dán vào bảng giỏ hàng hiện tại; xử lý được cả Product lẫn Combo.
   ──────────────────────────────────────────────────────────────── *@

@model List<HealthyFoodOrdering.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <h2 class="fw-bold mb-4">🛒 Giỏ hàng của bạn</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <p class="fs-5">Giỏ hàng đang trống.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-success me-2">Xem sản phẩm</a>
            <a asp-controller="Combo"   asp-action="Index" class="btn btn-success">Xem combo</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Hình</th>
                        <th>Tên</th>
                        <th>Loại</th>
                        <th>Đơn giá</th>
                        <th style="width:130px">Số lượng</th>
                        <th>Thành tiền</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@item.ImageUrl" alt="@item.DisplayName"
                                     style="width:60px;height:60px;object-fit:cover;border-radius:8px;">
                            </td>
                            <td class="fw-semibold">@item.DisplayName</td>
                            <td>
                                @if (item.Type == "Combo")
                                {
                                    <span class="badge bg-success">Combo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Sản phẩm</span>
                                }
                            </td>
                            <td>@item.Price.ToString("N0") VNĐ</td>

                            @* ── Cập nhật số lượng ── *@
                            <td>
                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post"
                                      class="d-flex align-items-center gap-1">
                                    <input type="hidden" name="id"   value="@(item.Type == "Combo" ? item.ComboId : item.ProductId)" />
                                    <input type="hidden" name="type" value="@item.Type" />
                                    <input type="number" name="quantity" value="@item.Quantity"
                                           min="1" class="form-control form-control-sm text-center"
                                           style="width:60px"
                                           onchange="this.form.submit()">
                                </form>
                            </td>

                            <td class="fw-bold text-success">@item.Total.ToString("N0") VNĐ</td>

                            @* ── Xóa ── *@
                            <td>
                                <a asp-controller="Cart" asp-action="Remove"
                                   asp-route-id="@(item.Type == "Combo" ? item.ComboId : item.ProductId)"
                                   asp-route-type="@item.Type"
                                   class="btn btn-outline-danger btn-sm rounded-pill"
                                   onclick="return confirm('Xóa khỏi giỏ hàng?')">
                                    🗑
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="5" class="text-end fw-bold fs-5">Tổng cộng:</td>
                        <td colspan="2" class="fw-bold fs-5 text-success">
                            @Model.Sum(x => x.Total).ToString("N0") VNĐ
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="d-flex justify-content-between mt-3">
            <a asp-controller="Combo" asp-action="Index" class="btn btn-outline-success">
                ← Tiếp tục mua
            </a>
            <a asp-controller="Order" asp-action="Checkout" class="btn btn-success px-5">
                Đặt hàng →
            </a>
        </div>
    }
</div>
