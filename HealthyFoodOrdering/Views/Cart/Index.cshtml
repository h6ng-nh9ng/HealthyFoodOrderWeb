@model List<HealthyFoodOrdering.Models.CartItem>
<div class="container mt-4">
    <h2>Giỏ hàng của bạn</h2>
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">Giỏ hàng trống. <a asp-controller="Home" asp-action="Index">Quay lại mua sắm!</a></div>
    }
    else
    {
        <table class="table table-bordered align-middle text-center">
            <thead class="table-light">
                <tr>
                    <th>Hình ảnh</th>
                    <th>Sản phẩm</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><img src="@item.ImageUrl" style="width:60px; height:60px; object-fit:cover; border-radius:5px;" /></td>
                        <td class="text-start">
                            <strong>@(item.Type == "Combo" ? item.ComboName : item.ProductName)</strong>
                            <br /><small class="text-muted">Loại: @item.Type</small>
                        </td>
                        <td>@item.Price.ToString("N0") VNĐ</td>
                        <td>
                            <form asp-action="UpdateQuantity" method="post" class="d-inline-flex gap-1">
                                <input type="hidden" name="id" value="@(item.Type == "Combo" ? item.ComboId : item.ProductId)" />
                                <input type="hidden" name="type" value="@item.Type" />
                                <input type="number" name="quantity" value="@item.Quantity" min="1"
                                       class="form-control form-control-sm text-center" style="width:80px;"
                                       onchange="this.form.submit()" />
                            </form>
                        </td>
                        <td class="fw-bold text-success">@item.Total.ToString("N0") VNĐ</td>
                        <td>
                            <a asp-action="Remove" asp-route-id="@(item.Type == "Combo" ? item.ComboId : item.ProductId)"
                               asp-route-type="@item.Type" class="btn btn-danger btn-sm">Xóa</a>
                        </td>
                    </tr>
                } 
            </tbody>
        </table>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <h4>Tổng tiền: <span class="text-danger">@Model.Sum(x => x.Total).ToString("N0") VNĐ</span></h4>
            <a asp-controller="Checkout" asp-action="Index" class="btn btn-success btn-lg">Tiến hành thanh toán</a>
        </div>
    }
</div>