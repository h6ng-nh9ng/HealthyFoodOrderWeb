@model HealthyFoodOrdering.Models.NutritionCombo
@{
    ViewData["Title"] = Model.ComboName;
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Tính giá sau giảm (null nếu không có giảm giá)
    var hasDiscount = Model.DiscountPercent > 0;
    var discountedPrice = hasDiscount
        ? Model.TotalPrice * (1 - Model.DiscountPercent / 100m)
        : (decimal?)null;
    var savings = hasDiscount ? Model.TotalPrice - discountedPrice!.Value : 0;
}

@* ═══════════════════════════════════════════════════════════
   BREADCRUMB
═══════════════════════════════════════════════════════════ *@
<div class="bg-light border-bottom py-2">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Trang chủ</a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-controller="Combo" asp-action="Index" class="text-decoration-none text-muted">Combo dinh dưỡng</a>
                </li>
                <li class="breadcrumb-item active fw-semibold text-truncate" style="max-width:200px">@Model.ComboName</li>
            </ol>
        </nav>
    </div>
</div>

@* ═══════════════════════════════════════════════════════════
   HERO: ẢNH + THÔNG TIN CHÍNH
═══════════════════════════════════════════════════════════ *@
<section class="py-5">
    <div class="container">
        <div class="row g-5 align-items-start">

            @* ── Cột trái: Ảnh ──────────────────────────────────── *@
            <div class="col-lg-5">
                <div class="position-relative">
                    <div class="rounded-4 overflow-hidden shadow" style="height:400px;">
                        <img src="@Url.Content("~/" + (Model.ImageUrl ?? "images/placeholder-combo.jpg").TrimStart('/'))"
                             alt="@Model.ComboName"
                             style="width:100%; height:100%; object-fit:cover;"
                             onerror="this.onerror=null; this.src='/images/placeholder-combo.jpg';">
                    </div>

                    @* Badge giảm giá góc trên phải *@
                    @if (hasDiscount)
                    {
                        <span class="badge bg-danger position-absolute top-0 end-0 m-3 px-3 py-2 rounded-3"
                              style="font-size:.9rem;">
                            🔖 -@Model.DiscountPercent%
                        </span>
                    }

                    @* Badge nổi bật góc trên trái *@
                    @if (Model.Featured)
                    {
                        <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-3 px-3 py-2 rounded-3"
                              style="font-size:.9rem;">
                            ⭐ Nổi bật
                        </span>
                    }
                </div>

                @* Số liệu tóm tắt dưới ảnh *@
                <div class="row g-0 mt-3 text-center bg-light rounded-4 py-3">
                    <div class="col border-end">
                        <div class="fw-bold fs-5 text-success">@Model.SoldQuantity</div>
                        <div class="text-muted" style="font-size:.78rem;">Đã bán</div>
                    </div>
                    <div class="col border-end">
                        <div class="fw-bold fs-5 text-success">@Model.ComboDetails.Count</div>
                        <div class="text-muted" style="font-size:.78rem;">Món ăn</div>
                    </div>
                    <div class="col">
                        <div class="fw-bold fs-5 text-success">@Model.TotalCalories</div>
                        <div class="text-muted" style="font-size:.78rem;">kcal</div>
                    </div>
                </div>
            </div>

            @* ── Cột phải: Thông tin ─────────────────────────────── *@
            <div class="col-lg-7">

                @* Badges trạng thái *@
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @if (!string.IsNullOrEmpty(Model.GoalType))
                    {
                        <span class="badge rounded-pill bg-success px-3 py-2">🎯 @Model.GoalType</span>
                    }
                    @if (Model.IsActive)
                    {
                        <span class="badge rounded-pill border border-success text-success bg-white px-3 py-2">✅ Còn phục vụ</span>
                    }
                </div>

                <h1 class="fw-bold mb-2">@Model.ComboName</h1>
                <p class="text-muted mb-4" style="line-height: 1.75;">@Model.Description</p>

                @* Khối giá *@
                <div class="rounded-4 p-4 mb-4" style="background:#f0faf4; border: 1px solid #c3e6cb;">
                    @if (hasDiscount)
                    {
                        <div class="text-muted text-decoration-line-through mb-1" style="font-size:.9rem;">
                            Giá gốc: @Model.TotalPrice.ToString("N0") VNĐ
                        </div>
                        <div class="d-flex align-items-baseline flex-wrap gap-2">
                            <span class="fw-bold text-danger" style="font-size: 2rem;">
                                @discountedPrice!.Value.ToString("N0") VNĐ
                            </span>
                            <span class="badge bg-danger rounded-pill px-2">
                                Tiết kiệm @savings.ToString("N0") VNĐ
                            </span>
                        </div>
                    }
                    else
                    {
                        <span class="fw-bold text-success" style="font-size: 2rem;">
                            @Model.TotalPrice.ToString("N0") VNĐ
                        </span>
                    }
                </div>

                @* Nút hành động *@
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Cart"
                       asp-action="AddCombo"
                       asp-route-id="@Model.Id"
                       class="btn btn-success btn-lg px-5 rounded-pill shadow-sm">
                        🛒 Thêm vào giỏ hàng
                    </a>
                    <a asp-controller="Combo"
                       asp-action="Index"
                       class="btn btn-outline-secondary btn-lg px-4 rounded-pill">
                        ← Xem tất cả combo
                    </a>
                </div>

                @* Ghi chú ngày tạo *@
                <p class="text-muted mt-4 mb-0" style="font-size:.8rem;">
                    📅 Cập nhật: @Model.CreatedDate.ToString("dd/MM/yyyy")
                </p>
            </div>

        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════
   THÔNG TIN DINH DƯỠNG TỔNG
═══════════════════════════════════════════════════════════ *@
<section class="py-5" style="background: #f8f9fa;">
    <div class="container">
        <h3 class="fw-bold text-center mb-2">📊 Thông tin dinh dưỡng tổng</h3>
        <p class="text-center text-muted mb-4 small">Tổng hợp từ tất cả món ăn trong combo</p>

        <div class="row row-cols-2 row-cols-md-4 g-3">

            @* ── Calories ── *@
            <div class="col">
                <div class="card border-0 shadow-sm rounded-4 text-center py-4 h-100"
                     style="border-top: 4px solid #e05a1e !important;">
                    <div style="font-size: 2.2rem; line-height:1;">🔥</div>
                    <div class="fw-bold mt-2" style="font-size:1.6rem; color:#e05a1e;">@Model.TotalCalories</div>
                    <div class="text-muted small mt-1">kcal<br>Năng lượng</div>
                </div>
            </div>

            @* ── Protein ── *@
            <div class="col">
                <div class="card border-0 shadow-sm rounded-4 text-center py-4 h-100"
                     style="border-top: 4px solid #198754 !important;">
                    <div style="font-size: 2.2rem; line-height:1;">💪</div>
                    <div class="fw-bold text-success mt-2" style="font-size:1.6rem;">@Model.TotalProtein.ToString("F1")g</div>
                    <div class="text-muted small mt-1">Protein<br>Chất đạm</div>
                </div>
            </div>

            @* ── Carbs ── *@
            <div class="col">
                <div class="card border-0 shadow-sm rounded-4 text-center py-4 h-100"
                     style="border-top: 4px solid #0dcaf0 !important;">
                    <div style="font-size: 2.2rem; line-height:1;">🌾</div>
                    <div class="fw-bold text-info mt-2" style="font-size:1.6rem;">@Model.TotalCarbs.ToString("F1")g</div>
                    <div class="text-muted small mt-1">Carbohydrate<br>Tinh bột</div>
                </div>
            </div>

            @* ── Fat ── *@
            <div class="col">
                <div class="card border-0 shadow-sm rounded-4 text-center py-4 h-100"
                     style="border-top: 4px solid #ffc107 !important;">
                    <div style="font-size: 2.2rem; line-height:1;">🥑</div>
                    <div class="fw-bold text-warning mt-2" style="font-size:1.6rem;">@Model.TotalFat.ToString("F1")g</div>
                    <div class="text-muted small mt-1">Fat<br>Chất béo</div>
                </div>
            </div>

        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════
   DANH SÁCH MÓN ĂN THÀNH PHẦN
═══════════════════════════════════════════════════════════ *@
<section class="py-5">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="fw-bold mb-1">🥗 Thành phần trong combo</h3>
                <p class="text-muted mb-0 small">Tất cả món ăn được kết hợp trong combo này</p>
            </div>
            <span class="badge bg-success rounded-pill px-3 py-2 fs-6">
                @Model.ComboDetails.Count món
            </span>
        </div>

        @if (!Model.ComboDetails.Any())
        {
            <div class="alert alert-light text-center text-muted rounded-4">
                Chưa có thông tin thành phần cho combo này.
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
                @foreach (var detail in Model.ComboDetails)
                {
                    var p = detail.Product;
                    var productHasDiscount = p.DiscountPercent > 0;

                    <div class="col">
                        <div class="card border-0 shadow-sm rounded-4 h-100">

                            @* Ảnh sản phẩm *@
                            <div style="height:170px; overflow:hidden;" class="rounded-top-4">
                                <img src="@Url.Content("~/" + (p.ImageUrl ?? "images/placeholder-product.jpg").TrimStart('/'))"
                                     alt="@p.Name"
                                     style="width:100%; height:100%; object-fit:cover;"
                                     onerror="this.onerror=null; this.src='/images/placeholder-product.jpg';">
                            </div>

                            <div class="card-body d-flex flex-column">

                                @* Badge GoalType của sản phẩm *@
                                @if (!string.IsNullOrEmpty(p.GoalType) && p.GoalType != "Healthy")
                                {
                                    <span class="badge bg-success rounded-pill mb-2 align-self-start"
                                          style="font-size:.7rem;">
                                        🎯 @p.GoalType
                                    </span>
                                }

                                <h6 class="fw-bold mb-1">@p.Name</h6>

                                @* Mô tả ngắn (giới hạn 2 dòng) *@
                                @if (!string.IsNullOrEmpty(p.Description))
                                {
                                    <p class="text-muted mb-2 flex-grow-1"
                                       style="font-size:.8rem; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                                        @p.Description
                                    </p>
                                }

                                @* Pills dinh dưỡng *@
                                <div class="d-flex flex-wrap gap-1 mb-3">
                                    <span class="badge bg-warning text-dark rounded-pill" style="font-size:.68rem;">
                                        🔥 @p.Calories kcal
                                    </span>
                                    <span class="badge bg-success rounded-pill" style="font-size:.68rem;">
                                        💪 @p.Protein.ToString("F1")g
                                    </span>
                                    <span class="badge bg-info text-dark rounded-pill" style="font-size:.68rem;">
                                        🌾 @p.Carbs.ToString("F1")g
                                    </span>
                                </div>

                                @* Giá + nút xem chi tiết *@
                                <div class="d-flex justify-content-between align-items-end mt-auto">
                                    <div>
                                        @if (productHasDiscount)
                                        {
                                            <div class="text-muted text-decoration-line-through"
                                                 style="font-size:.78rem;">
                                                @p.Price.ToString("N0") VNĐ
                                            </div>
                                            <div class="text-danger fw-semibold small">
                                                @p.FinalPrice.ToString("N0") VNĐ
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-success fw-semibold small">
                                                @p.Price.ToString("N0") VNĐ
                                            </div>
                                        }
                                    </div>

                                    <a asp-controller="Product"
                                       asp-action="Details"
                                       asp-route-id="@p.Id"
                                       class="btn btn-outline-success btn-sm rounded-pill px-3">
                                        Xem →
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @* ── CTA cuối trang ─────────────────────────────────────────────────── *@
        <div class="text-center mt-5 pt-3 border-top">
            <p class="text-muted mb-3">Bạn đã sẵn sàng đặt combo này?</p>
            <a asp-controller="Cart"
               asp-action="AddCombo"
               asp-route-id="@Model.Id"
               class="btn btn-success btn-lg px-5 rounded-pill me-2 shadow-sm">
                🛒 Thêm vào giỏ hàng
            </a>
            <a asp-controller="Combo"
               asp-action="Index"
               class="btn btn-outline-secondary btn-lg px-4 rounded-pill">
                Xem combo khác
            </a>
        </div>

    </div>
</section>
