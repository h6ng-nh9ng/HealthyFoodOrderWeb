@model IEnumerable<HealthyFoodOrdering.Models.NutritionCombo>
@{
    ViewData["Title"] = "Healthy Nutrition Combos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <h2 class="text-center mb-4">✨ Healthy Nutrition Combos</h2>
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var combo in Model.Where(c => c.IsActive))
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 rounded-4">
                    <img src="@combo.ImageUrl" class="card-img-top rounded-top-4" alt="@combo.ComboName" style="height:220px; object-fit:cover;">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@combo.ComboName</h5>
                        <p class="card-text text-muted">@combo.Description</p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="text-success fw-bold fs-5">@combo.TotalPrice.ToString("N0") VNĐ</span>
                            <a asp-action="Details" asp-route-id="@combo.Id" class="btn btn-outline-success rounded-pill">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>