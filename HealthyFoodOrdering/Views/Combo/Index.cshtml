@model IEnumerable<HealthyFoodOrdering.Models.NutritionCombo>
@{
    ViewData["Title"] = "Healthy Nutrition Combos";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Lấy danh sách ComboId đang có trong giỏ (để hiển thị badge "Đã thêm")
    // CartController.GetCartCount() trả về JSON — ở đây ta đọc thẳng từ Session nếu muốn.
    // Cách đơn giản nhất: truyền qua ViewBag từ ComboController nếu cần.
    // Hiện tại badge "Đã trong giỏ" được xử lý bằng JS nhỏ sau khi redirect.
}

<div class="container py-5">

    <h2 class="text-center mb-1 fw-bold">✨ Healthy Nutrition Combos</h2>
    <p class="text-center text-muted mb-5">Chọn combo phù hợp với mục tiêu sức khoẻ của bạn</p>

    @* ── Thông báo thêm thành công (TempData) ── *@
    @if (TempData["CartMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show text-center" role="alert">
            🛒 @TempData["CartMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var combo in Model.Where(c => c.IsActive))
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 rounded-4 position-relative">

                    @* ── Badge Discount ── *@
                    @if (combo.DiscountPercent > 0)
                    {
                        <span class="badge bg-danger position-absolute top-0 end-0 m-2 px-2 py-1 rounded-3"
                              style="z-index:1; font-size:.75rem;">
                            -@combo.DiscountPercent%
                        </span>
                    }

                    @* ── Badge GoalType (Giảm cân / Tăng cơ …) ── *@
                    @if (!string.IsNullOrEmpty(combo.GoalType))
                    {
                        <span class="badge bg-success position-absolute top-0 start-0 m-2 px-2 py-1 rounded-3"
                              style="z-index:1; font-size:.72rem;">
                            🎯 @combo.GoalType
                        </span>
                    }

                    <img src="@combo.ImageUrl"
                         class="card-img-top rounded-top-4"
                         alt="@combo.ComboName"
                         style="height:220px; object-fit:cover;">

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title fw-bold mb-1">@combo.ComboName</h5>
                        <p class="card-text text-muted small flex-grow-1">@combo.Description</p>

                        @* ── Thông tin dinh dưỡng tóm tắt ── *@
                        <div class="d-flex gap-2 flex-wrap mb-3 mt-1">
                            <span class="badge rounded-pill bg-warning text-dark small">
                                🔥 @combo.TotalCalories kcal
                            </span>
                            <span class="badge rounded-pill bg-info text-dark small">
                                💪 Protein @combo.TotalProtein.ToString("F1")g
                            </span>
                            <span class="badge rounded-pill bg-light text-dark border small">
                                🌾 Carbs @combo.TotalCarbs.ToString("F1")g
                            </span>
                        </div>

                        @* ── Giá & nút hành động ── *@
                        <div class="d-flex justify-content-between align-items-center mt-auto gap-2">

                            <div>
                                @if (combo.DiscountPercent > 0)
                                {
                                    <span class="text-decoration-line-through text-muted small me-1">
                                        @combo.TotalPrice.ToString("N0") VNĐ
                                    </span>
                                    <br />
                                    <span class="text-danger fw-bold fs-5">
                                        @((combo.TotalPrice * (1 - combo.DiscountPercent / 100m)).ToString("N0")) VNĐ
                                    </span>
                                }
                                else
                                {
                                    <span class="text-success fw-bold fs-5">
                                        @combo.TotalPrice.ToString("N0") VNĐ
                                    </span>
                                }
                            </div>

                            <div class="d-flex gap-2 flex-wrap justify-content-end">
                                @* Nút chi tiết *@
                                <a asp-controller="Combo"
                                   asp-action="Details"
                                   asp-route-id="@combo.Id"
                                   class="btn btn-outline-success btn-sm rounded-pill px-3">
                                    Chi tiết
                                </a>

                                @* ✅ NÚT THÊM VÀO GIỎ HÀNG *@
                                <a asp-controller="Cart"
                                   asp-action="AddCombo"
                                   asp-route-id="@combo.Id"
                                   class="btn btn-success btn-sm rounded-pill px-3"
                                   title="Thêm @combo.ComboName vào giỏ hàng">
                                    🛒 Thêm vào giỏ
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any(c => c.IsActive))
    {
        <div class="text-center py-5 text-muted">
            <p class="fs-5">Hiện chưa có combo nào. Vui lòng quay lại sau!</p>
        </div>
    }

</div>

@* ── Toast thông báo khi vừa thêm combo (dùng URL param ?added=1) ── *@
@section Scripts {
    <script>
        // Hiển thị toast Bootstrap nếu URL có ?added=1
        (function () {
            const params = new URLSearchParams(window.location.search);
            if (params.get('added') === '1') {
                // Xoá param khỏi URL mà không reload
                const url = new URL(window.location.href);
                url.searchParams.delete('added');
                history.replaceState(null, '', url.toString());

                // Tạo toast Bootstrap 5
                const toastHtml = `
                    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
                        <div id="cartToast" class="toast align-items-center text-bg-success border-0 show" role="alert">
                            <div class="d-flex">
                                <div class="toast-body">
                                    🛒 Đã thêm combo vào giỏ hàng!
                                </div>
                                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                                        data-bs-dismiss="toast"></button>
                            </div>
                        </div>
                    </div>`;
                document.body.insertAdjacentHTML('beforeend', toastHtml);
                setTimeout(() => document.getElementById('cartToast')?.closest('.position-fixed')?.remove(), 3000);
            }
        })();
    </script>
}
