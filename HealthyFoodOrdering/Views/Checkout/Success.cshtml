@model HealthyFoodOrdering.Models.Order

@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-3">
                <div class="card-body p-5 text-center">
                    <div class="text-success mb-4">
                        <i class="fas fa-check-circle fa-5x"></i>
                    </div>
                    
                    <h2 class="fw-bold text-success mb-2">Đặt Hàng Thành Công!</h2>
                    <p class="text-muted mb-4">Cảm ơn bạn đã lựa chọn bữa ăn dinh dưỡng tại Healthy Food.</p>
                    
                    <div class="bg-light p-4 rounded-3 text-start mb-4">
                        <h5 class="fw-bold mb-3 border-bottom pb-2 text-secondary">Thông tin đơn hàng #@Model.Id</h5>
                        
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Người nhận:</div>
                            <div class="col-sm-8 fw-bold">@Model.ReceiverName</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Số điện thoại:</div>
                            <div class="col-sm-8">@Model.Phone</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Địa chỉ nhận:</div>
                            <div class="col-sm-8">@Model.Address</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Ngày đặt:</div>
                            <div class="col-sm-8">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Hình thức:</div>
                            <div class="col-sm-8">
                                <span class="badge bg-info text-dark">@Model.PaymentMethod</span>
                            </div>
                        </div>
                    </div>

                    <div class="text-start mb-4">
                        <h5 class="fw-bold mb-3 text-secondary">Chi tiết thực đơn</h5>
                        <ul class="list-group list-group-flush border-top border-bottom">
                            @foreach (var detail in Model.OrderDetails)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <div>
                                        <span class="fw-bold text-success">
                                            x@detail.Quantity
                                        </span>

                                        @(detail.Product != null
                                            ? detail.Product.Name
                                            : detail.Combo?.ComboName)
                                    </div>

                                    <span class="text-muted">
                                        @((detail.Price * detail.Quantity).ToString("N0")) đ
                                    </span>
                                </li>
                            }
                        </ul>
                        <div class="d-flex justify-content-between fw-bold fs-5 mt-3 text-danger">
                            <span>TỔNG THANH TOÁN:</span>
                            <span>@Model.TotalAmount.ToString("N0") đ</span>
                        </div>
                    </div>

                    <hr />

                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-success btn-lg px-4 gap-3 rounded-pill">
                            <i class="fas fa-shopping-basket me-2"></i>Tiếp tục mua sắm
                        </a>
                        <a asp-controller="Order" asp-action="MyOrders" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">
                            <i class="fas fa-history me-2"></i>Lịch sử đơn hàng
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>