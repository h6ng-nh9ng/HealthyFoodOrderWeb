@model IEnumerable<HealthyFoodOrdering.Models.Product>
@{
    ViewData["Title"] = "Thực Đơn Sức Khỏe";
    Layout = "~/Views/Shared/_Layout.cshtml";
    // Kiểm tra xem người dùng hiện tại đã đăng nhập và có phải vai trò Admin không
    bool isAdmin = User.Identity.IsAuthenticated && User.IsInRole("Admin");
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="product-page-container">
    <div class="product-banner">
        <div class="banner-content">
            <span class="badge-green">Fresh & Organic</span>
            <h2>Thực Đơn Dinh Dưỡng Xanh</h2>
            <p>Khám phá các món ăn lành mạnh, giàu protein và được tính toán calo chi tiết.</p>
            
            @if (isAdmin)
            {
                <div class="admin-quick-add mt-3">
                    <a href="/Admin/Product/Create" class="btn-admin-create">
                        <i class="fas fa-plus-circle"></i> Thêm món ăn mới (Chế độ Admin)
                    </a>
                </div>
            }
        </div>
    </div>

    <div class="container mb-4">
        <form method="get" action="/Product/Index" class="row g-3 align-items-center bg-light p-3 rounded shadow-sm">
            <div class="col-auto">
                <label class="form-label fw-bold mb-0 text-secondary">🌱 Tìm theo Calo tối đa:</label>
            </div>
            <div class="col-auto">
                <input type="number" name="maxCalories" value="@ViewBag.MaxCalories" class="form-control" placeholder="Ví dụ: 500 kcal..." />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-success px-4">Lọc món</button>
                <a href="/Product/Index" class="btn btn-outline-secondary">Xóa lọc</a>
            </div>
        </form>
    </div>

    <div class="container my-5">
        <div class="product-grid">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="product-card-item @(isAdmin ? "admin-mode-card" : "")">
                        <div class="product-img-wrapper">
                            @{
                                var imgSrc = item.ImageUrl;
                                if (string.IsNullOrEmpty(imgSrc)) { imgSrc = "placeholder.jpg"; }
                                if (!imgSrc.StartsWith("/") && !imgSrc.StartsWith("http")) { imgSrc = "/uploads/products/" + imgSrc; }
                            }
                            <img src="@imgSrc" 
                                 onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(item.Name)&background=198754&color=fff&size=250';" 
                                 alt="@item.Name" />
                            
                            @if (item.Category != null)
                            {
                                <span class="product-tag">@item.Category.Name</span>
                            }
                            else
                            {
                                <span class="product-tag">Healthy</span>
                            }

                            @if (isAdmin)
                            {
                                <div class="admin-actions-overlay">
                                    <a href="/Admin/Product/Edit/@item.Id" title="Chỉnh sửa món ăn" class="admin-action-btn btn-edit">
                                        <i class="fas fa-edit"></i> Chỉnh sửa
                                    </a>
                                    <a href="/Admin/Product/Delete/@item.Id" title="Xóa món ăn" class="admin-action-btn btn-delete">
                                        <i class="fas fa-trash-alt"></i> Xóa
                                    </a>
                                </div>
                            }
                        </div>
                        
                        <div class="product-info">
                            <h4 class="product-title">@item.Name</h4>
                            <p class="product-desc">@(string.IsNullOrEmpty(item.Description) ? "Món ăn dinh dưỡng thơm ngon chuẩn vị, tốt cho sức khỏe cơ thể." : item.Description)</p>
                            
                            <div class="nutrition-facts-grid">
                                <span class="nutri-item"><i class="fas fa-fire text-danger"></i> Calo: <b>@item.Calories</b> kcal</span>
                                <span class="nutri-item"><i class="fas fa-egg text-warning"></i> Protein: <b>@item.Protein</b>g</span>
                                <span class="nutri-item"><i class="fas fa-bread-slice text-info"></i> Carbs: <b>@item.Carbs</b>g</span>
                                <span class="nutri-item"><i class="fas fa-cheese text-primary"></i> Fat: <b>@item.Fat</b>g</span>
                            </div>

                            <div class="product-footer">
                                <div class="price-container">
                                    <span class="product-price">@item.FinalPrice.ToString("#,##0") đ</span>
                                    @if (item.DiscountPercent > 0)
                                    {
                                        <span class="original-price">@item.Price.ToString("#,##0") đ</span>
                                    }
                                </div>
                                
                                <a asp-controller="Cart"
                                    asp-action="AddProduct"
                                    asp-route-id="@item.Id"
                                    class="btn-add-to-cart">
                                    <i class="fas fa-shopping-basket"></i> Thêm
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="no-products-wrapper">
                    <i class="fas fa-pizza-slice empty-icon"></i>
                    <p>Hiện tại không tìm thấy món ăn nào khớp trong cơ sở dữ liệu của bạn.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* Các CSS nền tảng cũ của bạn giữ nguyên, bổ sung thêm các Class Quản trị dưới đây */
    .product-page-container { background-color: #f8f9fa; min-height: 75vh; font-family: 'Segoe UI', Arial, sans-serif; padding-bottom: 60px; }
    .product-banner { background: linear-gradient(135deg, #198754 0%, #115c38 100%); padding: 50px 20px; text-align: center; color: #ffffff; margin-bottom: 40px; }
    .badge-green { background: rgba(255, 255, 255, 0.2); padding: 6px 16px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; display: inline-block; margin-bottom: 12px; }
    .product-banner h2 { font-size: 2.2rem; font-weight: 700; margin: 0 0 10px 0; }
    .product-banner p { font-size: 1rem; color: rgba(255, 255, 255, 0.85); max-width: 600px; margin: 0 auto; }

    .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 30px; max-width: 1200px; margin: 0 auto; padding: 0 15px; }
    .product-card-item { background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid #edf2f0; transition: all 0.3s ease; display: flex; flex-direction: column; }
    .product-card-item:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(25, 135, 84, 0.12); border-color: rgba(25, 135, 84, 0.2); }

    /* Viền đặc biệt đánh dấu Card ở giao diện Admin */
    .admin-mode-card { border: 1px dashed #198754 !important; }

    .product-img-wrapper { position: relative; width: 100%; height: 210px; background-color: #f1f3f2; overflow: hidden; }
    .product-img-wrapper img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
    .product-card-item:hover .product-img-wrapper img { transform: scale(1.05); }
    .product-tag { position: absolute; top: 12px; left: 12px; background: #198754; color: #fff; padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 600; box-shadow: 0 2px 5px rgba(0,0,0,0.1); z-index: 1; }

    /* LỚP PHỦ HÀNH ĐỘNG CHO ADMIN */
    .admin-actions-overlay {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.6); display: flex; flex-direction: column;
        justify-content: center; align-items: center; gap: 12px;
        opacity: 0; transition: opacity 0.3s ease; z-index: 2;
    }
    .product-img-wrapper:hover .admin-actions-overlay { opacity: 1; }
    
    .admin-action-btn {
        width: 130px; padding: 8px 0; border-radius: 6px; text-decoration: none !important;
        font-size: 0.88rem; font-weight: 600; text-align: center; color: #fff !important;
        display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: transform 0.2s;
    }
    .admin-action-btn:hover { transform: scale(1.05); }
    .admin-action-btn.btn-edit { background-color: #ffc107; color: #212529 !important; }
    .admin-action-btn.btn-delete { background-color: #dc3545; }

    /* PHẦN HIỂN THỊ ĐẦY ĐỦ THÔNG TIN DINH DƯỠNG */
    .product-info { padding: 20px; display: flex; flex-direction: column; flex-grow: 1; }
    .product-title { font-size: 1.15rem; font-weight: 600; color: #2d3748; margin: 0 0 8px 0; line-height: 1.4; text-align: left; }
    .product-desc { font-size: 0.88rem; color: #718096; margin: 0 0 15px 0; line-height: 1.5; text-align: left; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 38px; }

    .nutrition-facts-grid { 
        display: grid; grid-template-columns: 1fr 1fr; gap: 6px 12px;
        font-size: 0.82rem; color: #4a5568; background: #f8faf9; 
        padding: 10px; border-radius: 8px; margin-bottom: 15px;
    }
    .nutri-item { display: flex; align-items: center; gap: 5px; }

    .product-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 12px; border-top: 1px solid #f1f3f2; }
    .price-container { display: flex; flex-direction: column; align-items: flex-start; }
    .product-price { font-size: 1.25rem; font-weight: 700; color: #198754; line-height: 1; }
    .original-price { font-size: 0.85rem; color: #a0aec0; text-decoration: line-through; margin-top: 2px; }
    
    .btn-add-to-cart { background-color: #198754; color: white !important; text-decoration: none !important; padding: 8px 16px; border-radius: 20px; font-weight: 600; font-size: 0.9rem; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; transition: background 0.2s ease; }
    .btn-add-to-cart:hover { background-color: #146c43; }

    /* NÚT THÊM MÓN TRÊN BANNER */
    .btn-admin-create {
        background-color: #ffc107; color: #212529 !important; font-weight: 700;
        padding: 10px 24px; border-radius: 25px; text-decoration: none !important;
        display: inline-block; transition: all 0.2s; box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }
    .btn-admin-create:hover { background-color: #e0a800; transform: translateY(-2px); }

    .no-products-wrapper { grid-column: 1 / -1; text-align: center; padding: 70px 20px; color: #a0aec0; }
    .empty-icon { font-size: 3.5rem; margin-bottom: 15px; color: #cbd5e0; }
</style>