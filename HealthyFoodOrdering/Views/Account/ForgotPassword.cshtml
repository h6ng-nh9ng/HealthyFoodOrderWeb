@model HealthyFoodOrdering.Models.ForgotPasswordVM
@{
    ViewData["Title"] = "Quen mat khau";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page-wrapper">
    <div class="auth-card">
        <div class="auth-card-header">
            <div class="auth-icon"><i class="fas fa-unlock-alt"></i></div>
            <h3>Quen mat khau</h3>
            <p>Nhap email de mo phong gui lien ket dat lai mat khau.</p>
        </div>

        <div class="auth-card-body">
            <form asp-controller="Account" asp-action="ForgotPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="alert-box alert-danger"></div>

                <div class="custom-input-group">
                    <label asp-for="Email">Email dang ky</label>
                    <div class="input-wrapper">
                        <i class="fas fa-envelope input-icon"></i>
                        <input asp-for="Email" type="email" placeholder="Nhap email tai khoan" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="notice-box">
                    Chuc nang nay la gia lap cho bai tap: he thong khong gui email that.
                </div>

                <div class="profile-action-buttons">
                    <button type="submit" class="btn-save-profile">
                        <i class="fas fa-paper-plane"></i> Tiep tuc dat lai mat khau
                    </button>
                    <a asp-controller="Account" asp-action="Login" class="btn-home-back">
                        <i class="fas fa-arrow-left"></i> Quay lai dang nhap
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .auth-page-wrapper { display: flex; justify-content: center; align-items: center; padding: 60px 20px; background-color: #f4f7f5; min-height: 80vh; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .auth-card { background: #ffffff; width: 100%; max-width: 520px; border-radius: 16px; box-shadow: 0 10px 30px rgba(25, 135, 84, 0.08); overflow: hidden; border: 1px solid rgba(25, 135, 84, 0.1); }
    .auth-card-header { background: linear-gradient(135deg, #198754 0%, #146c43 100%); padding: 35px 20px 25px 20px; text-align: center; color: #ffffff; }
    .auth-icon { width: 70px; height: 70px; margin: 0 auto 12px; border-radius: 50%; background: rgba(255,255,255,0.16); display: flex; align-items: center; justify-content: center; font-size: 1.7rem; }
    .auth-card-header h3 { margin: 0 0 6px 0; font-weight: 700; }
    .auth-card-header p { margin: 0; color: rgba(255,255,255,0.9); }
    .auth-card-body { padding: 30px 35px; }
    .custom-input-group { margin-bottom: 18px; }
    .custom-input-group label { display: block; font-size: 0.85rem; font-weight: 500; color: #555; margin-bottom: 6px; text-align: left; }
    .input-wrapper { position: relative; display: flex; align-items: center; width: 100%; }
    .input-icon { position: absolute; left: 14px; color: #198754; font-size: 0.95rem; }
    .input-wrapper input { width: 100%; padding: 11px 12px 11px 40px; border: 1px solid #ddd; border-radius: 8px; font-size: 0.95rem; outline: none; transition: all 0.2s ease; color: #333; }
    .input-wrapper input:focus { border-color: #198754; box-shadow: 0 0 0 3px rgba(25, 135, 84, 0.15); }
    .notice-box { background-color: #fff8e1; border: 1px solid #ffe08a; color: #795200; border-radius: 8px; padding: 12px 14px; font-size: 0.9rem; margin-bottom: 18px; }
    .alert-box { padding: 12px 15px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; margin-bottom: 20px; }
    .alert-danger { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    .profile-action-buttons { display: flex; flex-direction: column; gap: 12px; margin-top: 15px; }
    .btn-save-profile, .btn-home-back { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 12px; border-radius: 8px; font-weight: 600; font-size: 0.95rem; text-decoration: none; transition: all 0.2s ease; cursor: pointer; text-align: center; box-sizing: border-box; }
    .btn-save-profile { background-color: #198754; color: #ffffff; border: none; width: 100%; }
    .btn-save-profile:hover { background-color: #146c43; transform: translateY(-1px); }
    .btn-home-back { background-color: #f8f9fa; color: #495057; border: 1px solid #ced4da; width: 100%; }
    .btn-home-back:hover { background-color: #e2e6ea; color: #212529; }
</style>
